<UserControl x:Class="ArasPatchUpgradeAssistant.Views.DirectoryValidationStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel>
                <TextBlock Text="升級目錄檢查"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#182230" />
                <TextBlock Text="依據第一步產生的 SETUP CMD 與 Support Root，檢查升級包的重要資料夾與檔案。"
                           Foreground="#667085"
                           Margin="0,5,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right"
                    Content="重新整理"
                    Command="{Binding RefreshCommand}"
                    Background="#1570EF"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="20,9"
                    Margin="16,4,0,0"
                    VerticalAlignment="Top" />
        </DockPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E0E5EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,18,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Upgrade Root" Foreground="#667085" />
                    <TextBlock Text="{Binding UpgradeRoot}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,4,12,0" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="版本" Foreground="#667085" />
                    <TextBlock Text="{Binding Version}" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="檢查時間" Foreground="#667085" />
                    <TextBlock Text="{Binding LastCheckedAt, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#ECFDF3" CornerRadius="7" Padding="14" Margin="0,0,8,0">
                <TextBlock Text="{Binding OkCount, StringFormat=OK  {0}}"
                           Foreground="#027A48"
                           FontSize="17"
                           FontWeight="SemiBold" />
            </Border>
            <Border Grid.Column="1" Background="#FEF3F2" CornerRadius="7" Padding="14" Margin="4,0">
                <TextBlock Text="{Binding MissingCount, StringFormat=Missing  {0}}"
                           Foreground="#B42318"
                           FontSize="17"
                           FontWeight="SemiBold" />
            </Border>
            <Border Grid.Column="2" Background="#FFFAEB" CornerRadius="7" Padding="14" Margin="8,0,0,0">
                <TextBlock Text="{Binding WarningCount, StringFormat=Warning  {0}}"
                           Foreground="#B54708"
                           FontSize="17"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#E0E5EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="1">
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      RowHeight="42">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="名稱" Binding="{Binding Name}" Width="150" />
                    <DataGridTextColumn Header="類型" Binding="{Binding Kind}" Width="80" />
                    <DataGridTextColumn Header="狀態" Binding="{Binding Status}" Width="90" />
                    <DataGridTextColumn Header="完整路徑" Binding="{Binding FullPath}" Width="*" />
                    <DataGridTextColumn Header="說明" Binding="{Binding ErrorMessage}" Width="140" />
                    <DataGridTemplateColumn Header="" Width="48">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="&#x1F4C1;"
                                        Command="{Binding DataContext.CreateFolderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="建立資料夾"
                                        Visibility="{Binding CanCreate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        FontSize="14" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
