<Window x:Class="ArasPatchUpgradeAssistant.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ArasPatchUpgradeAssistant.ViewModels"
        xmlns:views="clr-namespace:ArasPatchUpgradeAssistant.Views"
        Title="Aras Innovator Patches 升級助手"
        Width="1280"
        Height="820"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F8">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:SetupStepViewModel}">
            <views:SetupStepView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DirectoryValidationStepViewModel}">
            <views:DirectoryValidationStepView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UpgradeOptionsStepViewModel}">
            <views:UpgradeOptionsStepView />
        </DataTemplate>
        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#263449" />
            <Setter Property="Foreground" Value="#E9EEF5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34465F" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1D2939">
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top" Margin="4,8,4,24">
                    <TextBlock Text="Aras Innovator"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="22" />
                    <TextBlock Text="Patches 升級助手"
                               Foreground="#A9B8CC"
                               FontSize="15"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="1"
                            Content="1  基本設定 / 產生 CMD" />
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="2"
                            Content="2  升級目錄檢查" />
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="3"
                            Content="3  升級選項 / BAT 執行計畫" />
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="4"
                            Content="4  執行前檢查" />
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="5"
                            Content="5  執行升級命令" />
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="6"
                            Content="6  Log / Report 檢視" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Background="#172231"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,18,0,0">
                    <TextBlock Text="第一版僅產生設定檔與檢查目錄，不會執行 CMD、BAT 或 SQL。"
                               Foreground="#A9B8CC"
                               TextWrapping="Wrap"
                               FontSize="12"
                               LineHeight="18" />
                </Border>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentContent}"
                        Margin="24" />
    </Grid>
</Window>
